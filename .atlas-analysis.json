  "keyFeatures": [
    "Instant cloud terminals with Docker-powered sandboxes",
    "Connect any machine (BYOS) with lightweight agent",
    "Real-time WebSocket terminal streaming with xterm.js",
    "Secure by default with JWT auth, MFA, and audit logging",
    "Terminal session recording and replay",
    "Multi-language SDKs (Go, JS/TS, Python, Rust, Ruby, Java, .NET, PHP)",
    "CLI tools for terminal management and automation",
    "SSH gateway for traditional SSH access",
    "Stripe-backed billing integration"
  ],
  "publicApiSurface": [
    "POST /api/containers - Create container",
    "GET /api/containers - List containers",
    "GET /api/containers/:id - Get container details",
    "DELETE /api/containers/:id - Delete container",
    "POST /api/containers/:id/start - Start container",
    "POST /api/containers/:id/stop - Stop container",
    "GET /api/containers/:id/files/list - List files",
    "POST /api/containers/:id/files - Upload file",
    "GET /api/containers/:id/files - Download file",
    "DELETE /api/containers/:id/files - Delete file",
    "POST /api/agents/register - Register agent",
    "DELETE /api/agents/:id - Unregister agent",
    "WS /ws/terminal/:containerId - Terminal WebSocket",
    "WS /ws/agent/:agentId - Agent WebSocket",
    "rexec-cli - Command-line interface",
    "rexec-agent - Remote machine agent",
    "rexec-tui - Terminal UI dashboard",
    "rexec-ssh - SSH gateway server"
  ]
